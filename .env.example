# Copy to .env at the repo root. docker-compose reads these automatically.
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=secret
MONGO_DB=eloura

SERVER_PORT=5000
CLIENT_PORT=5173

# Auth — change JWT_SECRET to a long random string in any real environment
JWT_SECRET=dev_only_change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Image generation (optional). Leave blank to use the free keyless provider.
# Set an OpenAI key to generate via DALL·E securely from the server.
OPENAI_API_KEY=

# Cloudinary (optional). Leave blank to store the provider URL directly.
# Set all three to persist generated images to the Cloudinary CDN.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay payments (optional). Use TEST keys from the Razorpay dashboard.
# Leave blank to disable checkout (the app still works, just no purchases).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
